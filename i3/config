set $mod Mod4
font pango:JetBrains Mono 10

set $left h
set $down j
set $up k
set $right l
set $term alacritty
set $music ~/.config/sway/scripts/rofi_music
set $colorpicker ~/.config/sway/scripts/colorpicker
set $browser librewolf
set $filemanager thunar
set $launcher rofi -show drun

set $base #1e1e2e
set $text #cdd6f4
set $lavender #b4befe
set $mauve #cba6f7
set $overlay0 #6c7086
set $peach #fab387

default_border pixel 2
default_floating_border none
smart_gaps on
smart_borders on
gaps inner 0
gaps outer 8

exec_always --no-startup-id picom --config ~/.config/picom/picom.conf -b
exec_always --no-startup-id feh --bg-fill ~/.config/sway/scripts/bg_random_auto
exec_always --no-startup-id setxkbmap -layout tr -option caps:escape

exec --no-startup-id /usr/bin/lxpolkit
exec --no-startup-id nm-applet --indicator
exec --no-startup-id greenclip daemon
exec_always --no-startup-id killall dunst; dunst -conf ~/.config/dunst/dunstrc &
exec --no-startup-id thunar --daemon
exec --no-startup-id i3-msg workspace 1, workspace 2, workspace 3, workspace 4, workspace 5
exec mpd
exec mpDris2
exec pipewire
exec wireplumber &
exec pipewire-pulse
exec gentoo-pipewire-launcher
exec copyq --start-server

exec_always --no-startup-id sleep 1 && ~/.config/polybar/launch.sh
exec_always --no-startup-id ~/.config/i3/wallpaper_shuffler.sh

for_window [window_role="About"] floating enable
for_window [window_role="Preferences"] floating enable
for_window [window_type="dialog"] floating enable
for_window [window_type="menu"] floating enable
for_window [class="Pavucontrol"] floating enable
for_window [class="Blueman-manager"] floating enable
for_window [title="(?:Open|Save) (?:File|Folder|As)"] floating enable, resize set 800 600
for_window [title="Picture in picture"] floating enable, sticky enable

for_window [class="Google-chrome"] move container to workspace number 2
for_window [class="Thunar"] move container to workspace number 3
for_window [class="TelegramDesktop"] move container to workspace number 6
for_window [class="copyq"] floating enable, border pixel 2, move position center
for_window [class="LibreWolf"] focus_on_window_activation focus

client.focused           $lavender $base $text $lavender $mauve
client.focused_inactive  $overlay0 $base $text $overlay0 $overlay0
client.unfocused         $overlay0 $base $text $overlay0 $overlay0
client.urgent            $peach $base $peach $overlay0 $peach
client.placeholder       $base $base $text $overlay0 $overlay0
client.background        $base

bindsym $mod+t exec $term
bindsym $mod+q kill
bindsym $mod+d exec $launcher
bindsym $mod+m exec $music
bindsym $mod+n exec $filemanager
bindsym $mod+e exec element-desktop
bindsym $mod+w exec $browser
bindsym $mod+Shift+v exec copyq show
bindsym $mod+Shift+n exec --no-startup-id ~/.local/bin/read-mode.sh
bindsym $mod+o exec ~/.config/i3/scripts/RofiEmoji.sh

# Fullscreen screenshot
bindsym Print exec --no-startup-id "scrot '/home/malatesta/Pictures/%Y-%m-%d_%H%M%S.png' -e 'xclip -selection clipboard -t image/png -i $f' && notify-send 'Screenshot' 'Full screen captured and saved!'"

# Selected area screenshot
bindsym Shift+Print exec --no-startup-id "scrot -s '/home/malatesta/Pictures/%Y-%m-%d_%H%M%S.png' -e 'xclip -selection clipboard -t image/png -i $f' && notify-send 'Screenshot' 'Selected area captured and saved!'"

floating_modifier $mod
bindsym $mod+Mod1+r restart
bindsym $mod+Mod1+e exec ~/.config/sway/scripts/rofi_powermenu

bindsym XF86AudioRaiseVolume exec amixer -c 1 set Speaker 5%+
bindsym XF86AudioLowerVolume exec amixer -c 1 set Speaker 5%-
bindsym XF86AudioMute exec amixer -c 1 set Speaker toggle
bindsym XF86MonBrightnessUp exec light -A 5
bindsym XF86MonBrightnessDown exec light -U 5

bindsym $mod+$left focus left
bindsym $mod+$down focus down
bindsym $mod+$up focus up
bindsym $mod+$right focus right

bindsym $mod+Shift+$left move left
bindsym $mod+Shift+$down move down
bindsym $mod+Shift+$up move up
bindsym $mod+Shift+$right move right

bindsym $mod+1 workspace number 1
bindsym $mod+2 workspace number 2
bindsym $mod+3 workspace number 3
bindsym $mod+4 workspace number 4
bindsym $mod+5 workspace number 5
bindsym $mod+6 workspace number 6
bindsym $mod+7 workspace number 7
bindsym $mod+8 workspace number 8
bindsym $mod+9 workspace number 9
bindsym $mod+0 workspace number 10

bindsym $mod+Shift+1 move container to workspace number 1
bindsym $mod+Shift+2 move container to workspace number 2
bindsym $mod+Shift+3 move container to workspace number 3
bindsym $mod+Shift+4 move container to workspace number 4
bindsym $mod+Shift+5 move container to workspace number 5
bindsym $mod+Shift+6 move container to workspace number 6

bindsym $mod+b splith
bindsym $mod+v splitv
bindsym $mod+f fullscreen
bindsym $mod+x floating toggle
bindsym $mod+space focus mode_toggle
bindsym $mod+Shift+minus move scratchpad
bindsym $mod+minus scratchpad show
bindsym $mod+u [instance="scratchterm"] scratchpad show
bindsym $mod+ctrl+t exec alacritty --name scratchterm
for_window [instance="scratchterm"] move scratchpad

mode "resize" {
    bindsym $left resize shrink width 10 px or 10 ppt
    bindsym $down resize grow height 10 px or 10 ppt
    bindsym $up resize shrink height 10 px or 10 ppt
    bindsym $right resize grow width 10 px or 10 ppt
    bindsym Return mode "default"
    bindsym Escape mode "default"
}
bindsym $mod+r mode "resize"
